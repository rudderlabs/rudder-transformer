{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "npx lint-staged 2>&1 | tail -10; if [ ${PIPESTATUS[0]} -ne 0 ]; then echo 'BLOCK: lint-staged failed — fix lint/formatting issues before committing'; exit 2; fi",
            "statusMessage": "Running lint-staged on staged files"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run lint:*)",
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "Bash(npm run typecheck)",
      "Bash(npm run build:*)",
      "Bash(npx jest:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(npx tsc:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh api:*)",
      "Bash(gh run:*)"
    ],
    "deny": [
      "Edit(node_modules/**)",
      "Edit(dist/**)",
      "Edit(allure-results/**)",
      "Edit(reports/**)",
      "Edit(test_reports/**)",
      "Edit(package-lock.json)",
      "Read(node_modules/**)",
      "Read(dist/**)",
      "Read(allure-results/**)",
      "Read(reports/**)",
      "Read(test_reports/**)"
    ]
  }
}
